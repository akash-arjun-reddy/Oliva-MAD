{
  "version": 2,
  "builds": [
    {
      "src": "main_simple.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main_simple.py"
    }
  ],
  "functions": {
    "main_simple.py": {
      "runtime": "python3.11"
    }
  }
} 